# 生产/迁移用依赖服务连接配置
# 用于 migrate 命令：连接目标数据库执行迁移，并将各服务配置注入 ENV 供自定义脚本使用
# 使用方式：cp secret-config.yaml.example secret-config.yaml，填入真实连接信息
# 可通过环境变量 SECRET_PATH 指定自定义路径：
#   export SECRET_PATH=/path/to/secret-config.yaml
# K8s 部署时由 Secret 挂载至 /etc/data-migrator/secret-config.yaml

depServices:
  rds:
    source_type: internal   # internal, external
    type: dm8           # mariadb, dm8, kdb9
    host: "127.0.0.1"
    port: 5237
    user: "SYSDBA"
    password: "your_password"
    hostRead: "127.0.0.1"  # 只读副本，无则与 host 相同
    portRead: 5237
    admin_key: ""           # base64 编码的 root 凭据，如 "cm9vdDp5b3VyX3Bhc3N3b3Jk"
    mgmt_host: ""
    mgmt_port: 8888

  mongodb:
    host: "127.0.0.1"
    port: 27017
    user: "your_user"
    password: "your_password"
    replicaSet: ""
    options:
      authSource: "admin"
    source_type: internal
    admin_key: ""
    mgmt_host: ""
    mgmt_port: 8888

  opensearch:
    host: "127.0.0.1"
    port: 9200
    protocol: http          # http, https
    user: "admin"
    password: "your_password"

  redis:
    connectType: standalone # standalone, sentinel, cluster
    connectInfo:
      host: "127.0.0.1"
      port: 6379
      username: ""
      password: "your_password"
      masterHost: ""
      masterPort: 0
      slaveHost: ""
      slavePort: 0
      sentinelHost: ""
      sentinelPort: 0
      sentinelUsername: ""
      sentinelPassword: ""
      masterGroupName: ""

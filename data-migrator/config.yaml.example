# config.yaml — 服务列表与版本管理配置（提交到 git / K8s ConfigMap 挂载）
# 数据库连接配置请参考以下模板文件（不提交到 git）：
#   secret.yaml.example          → migrate 命令用，单个目标 DB 连接
#   verify_rds_config.yaml.example → verify 命令用，多 DB 类型对比

module: template
description: 配置模板

db_types:
  - mariadb
  - dm8
  - kdb9

databases:
  - adp

check_rules:
  check_type: 3 # CheckLatest = 1, CheckRecently = 2, CheckAll = 3
  allow_none_primary_key: false
  allow_foreign_key: false
  allow_python_exception: false
  

renamed_services:
# - old_name: old_name
#    new_name: new_name

services:
  service_name:
    project: <project_name>
    repo: <repo_name>
    ref: <ref_name>
    path: <migrations_path>
    # check_from: "1.0.0"  # 可选，从指定版本开始检测，不配置则检测所有版本

# ── Platform ─────────────────────────────────────────────────────────────────
# BKN Foundry host (without trailing slash). Use https for self-signed
# (the CLI is configured with --insecure via `kweaver auth login`).
# example: https://192.168.40.62
PLATFORM_HOST=https://your-platform-host

# LLM model ID from kweaver model factory.
# Find via: kweaver call /api/mf-model-manager/v1/llm/list?page=1&size=20
LLM_ID=
LLM_NAME=deepseek-v3.2

# ── MySQL business database ──────────────────────────────────────────────────
# MUST be reachable from the BKN Foundry (not from your laptop).
# Required permissions: CREATE TABLE / INSERT / SELECT / UPDATE on DB_NAME.
DB_HOST=10.0.0.1
DB_PORT=3306
DB_NAME=supply_chain
DB_USER=root
DB_PASS=changeme

# ── Mock business backend ────────────────────────────────────────────────────
# Local port for the mock ERP/MES that Skills call. Change if 8765 is in use.
TOOL_BACKEND_PORT=8765

# URL reachable from the execution-factory sandbox when builtin_skill_execute_script
# runs. Keep the default for local verification; set this to a routable host/IP if
# you want the platform-side Skill script to call the mock backend directly.
TOOL_BACKEND_PUBLIC_URL=http://127.0.0.1:8765

# ── Optional ─────────────────────────────────────────────────────────────────
# Set to 1 for verbose logging.
# DEBUG=1

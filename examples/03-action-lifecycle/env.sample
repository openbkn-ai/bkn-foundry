# MySQL datasource — must be reachable from the openbkn platform (K8s internal IP or public IP).
# No local MySQL client needed: CSV files are uploaded and imported by the platform.
#
# DB_HOST: the host the openbkn platform uses to connect (often a VPC internal IP like 10.0.0.x
#          or a public IP if the database has a public endpoint).
DB_HOST=10.0.0.1
DB_PORT=3306
# DB_NAME: an existing database the DB user can CREATE TABLE / INSERT / SELECT in.
DB_NAME=my_database
DB_USER=root
DB_PASS=changeme

# Set to 1 or true for extra diagnostics (passwords never printed).
# DEBUG=1

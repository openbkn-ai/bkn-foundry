{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "description": "请求体结构定义 - check",
    "required": [
        "resource",
        "operation",
        "method"
    ],
    "properties": {
        "resource": {
            "type": "object",
            "description": "资源信息",
            "required": [
                "id",
                "type"
            ],
            "properties": {
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "type": {
                    "type": "string",
                    "description": "资源类型"
                },
                "ancestors": {
                    "type": "array",
                    "description": "祖先信息",
                    "items": {
                        "type": "object",
                        "properties": {
                            "id": {
                                "type": "string"
                            },
                            "type": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "id",
                            "type"
                        ]
                    }
                },
                "created_by": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "operation": {
            "description": "操作",
            "type":"array",
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
        },
        "method": {
            "type": "string",
            "description": "方法",
            "enum": [
                "GET"
            ]
        }
    }
}